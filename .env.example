# ================================
# CONFIGURACIÓN PARA EL SERVIDOR
# ================================

# Configuración de la API del servidor
# API_HOST: Usar 0.0.0.0 para escuchar en todas las interfaces (producción)
#           Usar 127.0.0.1 para solo localhost (desarrollo)
API_HOST=0.0.0.0
API_PORT=36748
# API_URL: URL que usan los clientes/web para conectarse al servidor API
API_URL=http://127.0.0.1:36748

# URL interna para comunicación entre servicios en el mismo servidor
API_INTERNAL_URL=http://127.0.0.1:36748

# ================================
# CONFIGURACIÓN DE LA INTERFAZ WEB
# ================================
# API Key de administrador para la interfaz web
ADMIN_API_KEY=adm-aNCfSpfZcNmANH5AU4334BUXsEorm7Jf
SESSION_TIMEOUT_MINUTES=10

# URL pública del servidor (usada como sugerencia en la instalación de clientes)
#API_PUBLIC_URL=https://mi-servidor.ejemplo.com

# Configuración de Flask
# FLASK_HOST: Usar 0.0.0.0 para escuchar en todas las interfaces (producción)
#             Usar 127.0.0.1 para solo localhost (desarrollo)
FLASK_SECRET_KEY=tu-clave-secreta-muy-segura-cambiar-en-produccion
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=36749

# Credenciales de login de la interfaz web (cambiar en producción)
# Usuario por defecto: probaky
# Contraseña por defecto: admin123

# ================================
# CONFIGURACIÓN DE EMAIL (OPCIONAL)
# ================================
EMAIL_ENABLED=False
EMAIL_SEND_HOUR=8
EMAIL_SEND_MINUTE=0
EMAIL_RECIPIENTS=admin@ejemplo.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password

# ================================
# CONFIGURACIÓN PARA EL CLIENTE
# ================================
# Para cada cliente, solo necesita su API key (ahora gestionada desde la BD)
# Ejemplo para un cliente:
API_KEY=pbk-ejemploReemplazarConClaveRealDe32caracteres
# URL del servidor de monitoreo
API_URL=http://localhost:36748

# Tokens Proxmox (mantener aquí, NO pasar por CLI para evitar historial)
PROXMOX_TOKEN=root@pam!mi_token
PROXMOX_SECRET=12345678-90ab-cdef-1234-567890abcdef

# Verificación TLS del certificado de Proxmox (true por defecto)
# Proxmox usa certificados auto-firmados; cambia a false si la conexión falla por SSL
# Alternativa: apunta a una CA personalizada con PROXMOX_CA_BUNDLE
PROXMOX_VERIFY_TLS=false
#PROXMOX_CA_BUNDLE=/ruta/a/ca.pem

# Puedes usar argumentos CLI en cliente.py en lugar de estas variables
# Modo de depuración
DEBUG_MODE=False
DEBUG_API_CALLS=False
IS_REMOTE_DEBUG=False

# Configuración SSH para depuración remota
REMOTE_DEBUG_SSH_USER=root
REMOTE_DEBUG_SSH_HOST=server
REMOTE_DEBUG_SSH_PASS=
REMOTE_DEBUG_SSH_PORT=22