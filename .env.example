# ================================
# SERVIDOR - probakgo (Go)
# ================================
# Copia este archivo a .env y ajusta los valores.
# Ver .env.server.example para documentación completa del servidor.
# Ver .env.client.example para configuración del cliente (nodo Proxmox).

API_HOST=0.0.0.0
API_PORT=36748

DATABASE_PATH=./probakgo_data.db

# Genera una clave segura con: openssl rand -base64 32
SESSION_KEY=change-me-in-production-32bytes!

TIMEZONE=Europe/Madrid

# Marcar true si el servidor está detrás de HTTPS (activa Secure en la cookie de sesión)
SESSION_SECURE=false

# Orígenes de confianza para CSRF (host:puerto, separados por coma). Necesario con proxy inverso.
# CSRF_TRUSTED_ORIGINS=mi-dominio.com,localhost:36748
