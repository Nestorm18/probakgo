# =================================
# SERVIDOR - probakgo (Go)
# =================================
# Copia este archivo a .env junto al binario.

# API_HOST: 0.0.0.0 escucha en todas las interfaces.
#           127.0.0.1 solo permite acceso local.
API_HOST=0.0.0.0
API_PORT=36748

# =================================
# BASE DE DATOS
# =================================
DATABASE_PATH=./probakgo_data.db

# =================================
# SEGURIDAD
# =================================
# Deja SESSION_KEY sin definir: probakgo genera una clave aleatoria segura
# durante el primer arranque y la persiste en .env.
# SESSION_KEY=<clave-aleatoria-secreta>

# Activalo si la aplicacion se sirve mediante HTTPS.
SESSION_SECURE=false

# Redes CIDR de proxies inversos autorizados a enviar X-Forwarded-*.
# Vacio por defecto: un cliente directo no puede falsear su IP.
# TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Origenes adicionales para proteccion CSRF, separados por comas.
# Incluye siempre esquema y host, por ejemplo:
# CSRF_TRUSTED_ORIGINS=https://monitor.example,https://monitor.interno.example

# =================================
# ZONA HORARIA
# =================================
TIMEZONE=Europe/Madrid

# =================================
# DESARROLLO / ACTUALIZACIONES
# =================================
# DEV=true

# Solo necesario para actualizaciones desde repositorios privados.
# GITHUB_TOKEN=ghp_...
