# ================================
# SERVIDOR - probakgo (Go)
# ================================
# Copia este archivo a .env en el mismo directorio del binario.

# API_HOST: 0.0.0.0 escucha en todas las interfaces (producción)
#           127.0.0.1 solo localhost (desarrollo)
API_HOST=0.0.0.0
API_PORT=36748

# ================================
# BASE DE DATOS
# ================================
DATABASE_PATH=./probakgo_data.db

# ================================
# SEGURIDAD
# ================================
# SESSION_KEY debe tener exactamente 32 bytes para AES-256.
# Genera uno con: openssl rand -base64 32
SESSION_KEY=change-me-in-production-32bytes!

# ================================
# ZONA HORARIA
# ================================
# Usada para el scheduler de email diario.
TIMEZONE=Europe/Madrid

# ================================
# EMAIL
# ================================
# El email se configura desde la interfaz web en /settings/email
# (host SMTP, contraseña, destinatarios, hora de envío).
# No se necesitan variables de entorno para email.
