# ================================
# SERVIDOR - probakgo (Go)
# ================================
# Copia este archivo a .env en el mismo directorio del binario.

# API_HOST: 0.0.0.0 escucha en todas las interfaces (producción)
#           127.0.0.1 solo localhost (desarrollo)
API_HOST=0.0.0.0
API_PORT=36748

# ================================
# BASE DE DATOS
# ================================
DATABASE_PATH=./probakgo_data.db

# ================================
# SEGURIDAD
# ================================
# SESSION_KEY debe tener exactamente 32 bytes para AES-256.
# Genera uno con: openssl rand -base64 32
SESSION_KEY=change-me-in-production-32bytes!

# Marcar true si el servidor está detrás de HTTPS (activa Secure en la cookie de sesión).
SESSION_SECURE=false

# Orígenes de confianza para la protección CSRF (host:puerto, separados por coma).
# Necesario cuando se accede por dominio y por IP al mismo tiempo, o con proxy inverso.
# CSRF_TRUSTED_ORIGINS=mi-dominio.com,localhost:36748

# ================================
# ZONA HORARIA
# ================================
# Usada para el scheduler de email diario.
TIMEZONE=Europe/Madrid

# ================================
# DESARROLLO / ACTUALIZACIONES
# ================================
# Activa la barra de debug en la interfaz web.
# DEV=true

# Token de GitHub para auto-update desde repos privados (opcional si el repo es público).
# GITHUB_TOKEN=ghp_...
