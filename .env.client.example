# ================================
# CLIENTE - probakgo-client (Go)
# ================================
# Instalado en /opt/probakgo/.env en cada nodo Proxmox.
# Generado automáticamente por: probakgo-client install

# URL del servidor probakgo
API_URL=http://your-server:36748

# API key del servidor (crear desde la interfaz web, debe empezar con pbk-)
API_KEY=pbk-replace-with-real-key-here

# Token de la API de Proxmox (generado automáticamente por install)
PROXMOX_TOKEN=root@pam!probakgo-client
PROXMOX_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Verificación TLS del certificado de Proxmox
# Proxmox usa certificados auto-firmados por defecto → false
PROXMOX_VERIFY_TLS=false
# PROXMOX_CA_BUNDLE=/ruta/a/ca.pem   # opcional: CA personalizada

# Tipo de servidor (dejar vacío para auto-detección desde /etc/issue)
# SERVER_TYPE=pve   # o pbs

# Modo depuración
DEBUG_MODE=false
DEBUG_API_CALLS=false

# Token de GitHub para auto-update desde repos privados (escrito automáticamente por install si está en el entorno)
# GITHUB_TOKEN=ghp_...
