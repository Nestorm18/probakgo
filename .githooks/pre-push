#!/bin/sh
# Blocks pushing to master if the version in main.go already has a git tag.
# Install once: git config core.hooksPath .githooks

while read local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/master)
      SERVER_VER=$(grep -oP 'var version = "\K[^"]+' main.go)
      CLIENT_VER=$(grep -oP 'var version = "\K[^"]+' client/main.go)
      if [ "$SERVER_VER" != "$CLIENT_VER" ]; then
        echo "ERROR: server version ($SERVER_VER) != client version ($CLIENT_VER) — keep them in sync"
        exit 1
      fi
      LATEST_TAG=$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//' || echo "")
      if [ -n "$LATEST_TAG" ] && [ "$SERVER_VER" = "$LATEST_TAG" ]; then
        echo "ERROR: version $SERVER_VER already released as v$LATEST_TAG"
        echo "       Bump var version in main.go and client/main.go before pushing to master."
        exit 1
      fi
      ;;
  esac
done
exit 0
