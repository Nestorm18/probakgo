#!/bin/sh
# Bump patch version in main.go and client/main.go before each push

set -e

# Read current version from main.go
CURRENT=$(grep -oP '(?<=var version = ")\d+\.\d+\.\d+' main.go)
if [ -z "$CURRENT" ]; then
    echo "pre-push: could not read version from main.go" >&2
    exit 1
fi

# Split and increment patch
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

echo "pre-push: bumping version $CURRENT → $NEW_VERSION"

# Update both files
sed -i "s/var version = \"$CURRENT\"/var version = \"$NEW_VERSION\"/" main.go
sed -i "s/var version = \"$CURRENT\"/var version = \"$NEW_VERSION\"/" client/main.go

# Commit the bump
git add main.go client/main.go
git commit -m "chore: bump version to $NEW_VERSION"
